# QChain deployment environment.
#
# Copy this file to qchain.env and edit. The systemd units below load
# qchain.env via EnvironmentFile= so changes here take effect after
# `systemctl restart qchain-*`.
#
# This file lives at /etc/qchain/qchain.env on the deployed VM by
# convention. The systemd units reference that path.
#
# DO NOT COMMIT THE FILLED-IN qchain.env TO GIT.
# Only this template (.example) belongs in the repo.

# Bearer token that the dashboard accepts for /api/* and /ws endpoints.
# Generate once with:
#     python -c "import secrets; print(secrets.token_urlsafe(32))"
# and share with the grant reviewer or anyone who should be able to
# interact with the chain (mine blocks, submit transactions, etc.).
# Read-only endpoints (chain state) are also gated by this token —
# the dashboard's UI itself prompts the user for the token.
QCHAIN_DASHBOARD_TOKEN=REPLACE_ME_WITH_A_SECRET_TOKEN

# Public bind address for all services. The dashboard.server CLI
# binds BOTH its p2p socket and its HTTP dashboard to this address
# (current implementation couples them). For a deployment where
# the dashboard is public but p2p should stay internal:
#
#   Set this to 0.0.0.0 (so the dashboard is reachable from outside),
#   and rely on the VM's firewall to block the p2p ports
#   (QCHAIN_NODE_*_PORT below) from the public internet. Only the
#   dashboard ports (QCHAIN_DASHBOARD_PORT, QCHAIN_NODE_2_HTTP_PORT
#   on localhost, QCHAIN_NODE_3_HTTP_PORT on localhost) should be
#   reachable, and only QCHAIN_DASHBOARD_PORT from outside the VM.
#
# See deploy/firewall-setup.md for the exact ufw/iptables commands.
#
# If you want defense-in-depth (NOT rely on the firewall), set this
# to 127.0.0.1 and SSH-tunnel the dashboard from outside:
#   ssh -L 8101:127.0.0.1:8101 qchain@VM_IP
QCHAIN_DASHBOARD_BIND=0.0.0.0

# Dashboard HTTP port. The grant reviewer hits http://VM_IP:THIS_PORT/
# Default 8101 is convention; change only if you have a port conflict.
QCHAIN_DASHBOARD_PORT=8101

# P2P internal port for the bootstrap node (node 1).
# Followers connect to 127.0.0.1:THIS_PORT on startup.
QCHAIN_NODE_1_PORT=19101

# P2P internal port for node 2 (follower).
QCHAIN_NODE_2_PORT=19102

# P2P internal port for node 3 (follower).
QCHAIN_NODE_3_PORT=19103

# Internal-only HTTP ports for nodes 2 and 3. These dashboards bind to
# 127.0.0.1 so they're reachable only from inside the VM (useful for
# debugging via curl/SSH tunnel, not exposed to the public). Node 1's
# dashboard is what the grant reviewer sees; it uses
# QCHAIN_DASHBOARD_PORT above and binds to QCHAIN_DASHBOARD_BIND.
QCHAIN_NODE_2_HTTP_PORT=8102
QCHAIN_NODE_3_HTTP_PORT=8103

# How often the auto-miner triggers a new block (in seconds).
# 15 seconds gives a "feels alive but not noisy" demo rate.
# Set higher (60+) if you want a slower-paced demo.
QCHAIN_AUTOMINE_INTERVAL=15

# Optional: pin the user the services run as. Default 'qchain' assumes
# you ran the setup script which creates that user.
QCHAIN_USER=qchain
